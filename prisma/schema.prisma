generator client {
  provider = "prisma-client"
  output   = "../lib/prisma"
  previewFeatures = ["fullTextSearchPostgres"]
}
// 

datasource db {
  provider = "postgresql"
}



model User {
  id       String @id @default(uuid())
  username String @unique @map("username")
  email    String @unique @map("email")
  password String @unique @map("password")
  phone     String @default("wo de shouji")

  @@map("user")
}

model Products {
  id           String  @id @default(uuid())
  productTitle String  @map("product_title")
  productName  String  @map("product_name")
  image        String  @map("product_image")
  description  String  @map("product_description")
  price        Float   @map("price")
  category     String  @map("category")
  gender       String  @map("gender")
  cart       CartItems[]
  purchased PurchasedProduct[]
  @@map("products")
}

model CartItems{
  cartId String @id @default(uuid())
  productId String @unique
  userId String 
  pId Products @relation(fields: [productId], references: [id])
  total_Amount Int
  color String  
  Quantity Int
  size String 
  viewCart Boolean?  
}

model PurchasedProduct{
  acquiredId String @id @default(uuid()) 
  productId String? 
  TransactionString String?
  PhoneNumber String?
  Amount Int? 
  Location String?
  MerchantRequestID String?
  product String
  purchasedId Products @relation(fields: [product] , references: [id])
  ResultCode String 
}
